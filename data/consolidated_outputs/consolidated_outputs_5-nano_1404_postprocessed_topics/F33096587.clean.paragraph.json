      {
        "para_id": "p2",
        "items": [],
        "meta": {
          "skipped": false,
          "skip_reason": null,
          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 4854,
          "unit_kind": "paragraph"
        },
        "text": "The European Commission carried out a fitness check on digital fairness in 2024, assessing possible regulatory gaps in the EU consumer protection framework. The findings of the Fitness Check highlight some shortcomings in the protection of consumers and areas of legal uncertainty.",
        "chunk_meta": {
          "section_id": "s3",
          "section_path": [
            "Contribution of CPME",
            "CONTENTS"
          ],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 42,
