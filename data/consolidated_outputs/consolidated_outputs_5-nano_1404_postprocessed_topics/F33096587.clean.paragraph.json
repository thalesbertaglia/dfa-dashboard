        "items": [
          {
            "topic": "Design Patterns",
            "topic_source": "dfa",
            "evidence_quotes": [
              {
                "quote": "manipulative interfaces"
              }
            ]
          },
          {
            "topic": "Influencer Marketing",
            "topic_source": "dfa",
            "evidence_quotes": [
              {
                "quote": "social media trading practices of influencers"
