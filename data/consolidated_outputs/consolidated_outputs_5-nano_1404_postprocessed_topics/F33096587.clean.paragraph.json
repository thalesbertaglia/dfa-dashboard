        },
        "text": "The European Commission is conducting a consultation on the next Digital Fairness Act until 24 October.",
        "chunk_meta": {
          "section_id": "s3",
          "section_path": [
            "Contribution of CPME",
            "CONTENTS"
          ],
          "span": null,
          "chunk_quality": "ok",
