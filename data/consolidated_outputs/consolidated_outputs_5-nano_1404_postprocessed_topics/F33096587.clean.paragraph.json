          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 5594,
          "unit_kind": "paragraph"
        },
        "text": "There is a real risk of regulatory fragmentation in the area of consumption in the EU, due to differences in interpretation and transposition into national laws.",
        "chunk_meta": {
          "section_id": "s8",
          "section_path": [
            "Contribution of CPME",
            "(2) COMBATING REGULATORY FRAGMENTATION"
          ],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 26,
          "char_len": 161
        }
      },
      {
        "para_id": "p22",
        "items": [
          {
            "topic": "Design Patterns",
            "topic_source": "dfa",
            "evidence_quotes": [
              {
                "quote": "design of interfaces, software or infrastructure"
