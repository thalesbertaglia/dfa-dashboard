          "skip_reason": null,
          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 5156,
          "unit_kind": "paragraph"
        },
        "text": "For CPME, it is essential that this future framework contributes to strengthening consumer confidence, but also to maintaining a competitive environment where businesses, especially SMEs, can innovate, invest and grow in the Single Market.",
        "chunk_meta": {
          "section_id": "s4",
          "section_path": [
            "Contribution of CPME",
            "OVERALL COMMENTS"
          ],
          "span": null,
