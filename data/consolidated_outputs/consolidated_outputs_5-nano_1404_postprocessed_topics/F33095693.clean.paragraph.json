          "errors": [],
          "repaired": false,
          "latency_ms": 20754,
          "unit_kind": "paragraph"
        },
        "text": "Marketing is explicitly excluded from the definition of 'harmful manipulation' that would result in a prohibition under the AI Act.",
        "chunk_meta": {
          "section_id": "s1",
          "section_path": [
            "The DFA needs to prevent commercial exploitation of emotional attachment to AI systems"
          ],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 20,
          "char_len": 131
        }
      },
