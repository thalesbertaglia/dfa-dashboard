          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 3311,
          "unit_kind": "paragraph"
        },
        "text": "The Digital Fairness Act is a last-minute opportunity to avoid these entirely foreseeable scenarios.",
        "chunk_meta": {
          "section_id": "s4",
          "section_path": [
