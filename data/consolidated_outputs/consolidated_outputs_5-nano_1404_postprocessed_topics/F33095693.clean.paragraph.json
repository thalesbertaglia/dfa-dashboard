          "chunk_word_count": 17,
          "char_len": 106
        }
      },
      {
        "para_id": "p16",
        "items": [
          {
            "topic": "Design Patterns",
            "topic_source": "dfa",
            "evidence_quotes": [
              {
                "quote": "products that foster emotional attachment"
