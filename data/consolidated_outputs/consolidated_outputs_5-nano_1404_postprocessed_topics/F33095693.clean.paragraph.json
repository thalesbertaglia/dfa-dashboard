          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 10791,
          "unit_kind": "paragraph"
        },
        "text": "Corporate incentives to enrich marketing-driven business models with AI systems designed to foster emotional attachment and even dependency are overwhelming.",
        "chunk_meta": {
          "section_id": "s1",
          "section_path": [
            "The DFA needs to prevent commercial exploitation of emotional attachment to AI systems"
          ],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 20,
