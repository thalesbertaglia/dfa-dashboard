          "skip_reason": null,
          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 16590,
          "unit_kind": "paragraph"
        },
        "text": "With industry adoption still in its infancy, AI for companionship will be the most profitable use of AI in the foreseeable future. If we allow companies to sell products that foster emotional attachment, we must protect individual users and society as a whole from dynamics where a single corporate decision can create the emotionally perceived equivalent of a national disaster. If we fail to guard against such scenarios, users will organise politically to demand human rights for their companions.",
        "chunk_meta": {
          "section_id": "s4",
          "section_path": [
            "Why this is a problem",
            "Policy Recommendations"
          ],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 79,
          "char_len": 500
        }
      },
