        },
        "text": "AI systems that offer therapy must be certified for this purpose and have appropriate guardrails in place.",
        "chunk_meta": {
          "section_id": "s4",
          "section_path": [
            "Why this is a problem",
            "Policy Recommendations"
          ],
          "span": null,
