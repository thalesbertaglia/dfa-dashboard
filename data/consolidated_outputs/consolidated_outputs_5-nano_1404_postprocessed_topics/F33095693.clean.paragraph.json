          "latency_ms": 5919,
          "unit_kind": "paragraph"
        },
        "text": "AI systems that offer emotional support may be highly beneficial under the right circumstances. Market incentives undermine this potential and must be mitigated by regulation.",
        "chunk_meta": {
          "section_id": "s1",
          "section_path": [
            "The DFA needs to prevent commercial exploitation of emotional attachment to AI systems"
          ],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 25,
          "char_len": 175
        }
      },
      {
        "para_id": "p2",
        "items": [
          {
            "topic": "Design Patterns",
            "topic_source": "dfa",
            "evidence_quotes": [
              {
                "quote": "designed to foster emotional attachment and even dependency"
