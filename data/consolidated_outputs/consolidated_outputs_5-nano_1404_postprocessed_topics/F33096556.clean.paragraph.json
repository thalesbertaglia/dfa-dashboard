          "errors": [],
          "repaired": false,
          "latency_ms": 5002,
          "unit_kind": "paragraph"
        },
        "text": "Undermining the Commission's ongoing work on simplification and competitiveness",
        "chunk_meta": {
          "section_id": "s4",
