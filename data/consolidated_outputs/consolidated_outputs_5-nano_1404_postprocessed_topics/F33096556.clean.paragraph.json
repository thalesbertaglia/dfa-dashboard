          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 3370,
          "unit_kind": "paragraph"
        },
        "text": "The focus should now be on effective implementation and consistent enforcement of existing legislation rather than adding further rules. Eurofinas stands ready to work with the European Commission to ensure a coherent, proportionate, and competitive regulatory environment that protects consumers while supporting innovation and financial inclusion across Europe.",
        "chunk_meta": {
          "section_id": "s5",
          "section_path": [
            "Conclusions"
          ],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 48,
          "char_len": 363
        }
      },
      {
