          "repaired": false,
          "latency_ms": 5112,
          "unit_kind": "paragraph"
        },
        "text": "Eurofinas welcomes the opportunity to provide feedback on the European Commission's Digital Fairness Act (DFA) initiative.",
        "chunk_meta": {
          "section_id": "s2",
          "section_path": [
            "Eurofinas: Digital Fairness Act",
            "General comments"
          ],
          "span": null,
          "chunk_quality": "ok",
