          "skip_reason": null,
          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 3855,
          "unit_kind": "paragraph"
        },
        "text": "CODc",
        "chunk_meta": {
          "section_id": "s4",
          "section_path": [
            "2.1 Freedom to set and retain preferred defaults"
          ],
          "span": null,
          "chunk_quality": "ok",
