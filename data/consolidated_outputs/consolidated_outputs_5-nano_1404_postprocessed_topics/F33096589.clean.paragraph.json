        },
        "text": "Comments on the Digital Fairness Act Public Consultation",
        "chunk_meta": {
          "section_id": "s1",
          "section_path": [
            "Coalition for Open Digital Ecosystems"
          ],
          "span": null,
          "chunk_quality": "ok",
