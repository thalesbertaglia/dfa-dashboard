        "items": [
          {
            "topic": "Design Patterns",
            "topic_source": "dfa",
            "evidence_quotes": [
              {
                "quote": "manipulative commercial practices."
              },
              {
                "quote": "persuasive techniques"
              }
            ]
          },
          {
