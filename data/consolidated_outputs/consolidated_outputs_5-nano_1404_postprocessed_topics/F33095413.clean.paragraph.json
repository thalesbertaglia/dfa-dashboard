        ],
        "meta": {
          "skipped": false,
          "skip_reason": null,
          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 28734,
          "unit_kind": "paragraph"
        },
        "text": "Children's developing cognitive and emotional capacities make them especially susceptible to manipulative commercial practices. As their ability to understand and critically assess persuasive techniques is still forming, they are more easily influenced by digital marketing strategies. According to recent research by Better Internet for Kids (BIK), children under 12 are particularly vulnerable to such tactics due to their limited awareness of advertising intent and the mechanisms behind it. This vulnerability can result in negative compulsive behaviours such as excessive screen time, unintended purchases, exposure to targeted content that shapes their thinking, and the sharing of personal data. Therefore, children should not only be recognised as a vulnerable group under the proposed Act, but placed at its very core.",
        "chunk_meta": {
          "section_id": "s0",
          "section_path": [],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 118,
          "char_len": 827
        }
      },
      {
        "para_id": "p15",
        "items": [],
        "meta": {
