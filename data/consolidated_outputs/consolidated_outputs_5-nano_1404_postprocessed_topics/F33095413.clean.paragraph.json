          "latency_ms": 15047,
          "unit_kind": "paragraph"
        },
        "text": "The vulnerability of children",
        "chunk_meta": {
          "section_id": "s0",
          "section_path": [],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 4,
          "char_len": 29
