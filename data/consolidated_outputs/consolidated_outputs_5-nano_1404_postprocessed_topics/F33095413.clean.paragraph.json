          "repaired": false,
          "latency_ms": 5771,
          "unit_kind": "paragraph"
        },
        "text": "Digital accessibility",
        "chunk_meta": {
          "section_id": "s0",
          "section_path": [],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 2,
          "char_len": 21
        }
      },
      {
        "para_id": "p16",
        "items": [
          {
            "topic": "Gaming",
            "topic_source": "dfa",
            "evidence_quotes": [
              {
                "quote": "gaming industry"
              }
            ]
          }
        ],
        "meta": {
          "skipped": false,
          "skip_reason": null,
          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 31845,
          "unit_kind": "paragraph"
        },
        "text": "The proposed Act should promote digital accessibility and inclusive design of digital services and platforms, especially from the earliest design stages. This is particularly important for the gaming industry and social platforms, where inclusive design (in terms of gender, cultural background, and language) is essential.",
        "chunk_meta": {
          "section_id": "s0",
          "section_path": [],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 45,
          "char_len": 323
        }
      },
      {
        "para_id": "p17",
        "items": [],
        "meta": {
          "skipped": false,
          "skip_reason": null,
          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 7192,
          "unit_kind": "paragraph"
        },
        "text": "The use of AI",
        "chunk_meta": {
          "section_id": "s0",
          "section_path": [],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 4,
          "char_len": 13
        }
      },
      {
        "para_id": "p18",
        "items": [
          {
            "topic": "Design Patterns",
            "topic_source": "dfa",
            "evidence_quotes": [
              {
                "quote": "capture and retain users' attention for as long as possible"
              }
            ]
          }
        ],
        "meta": {
          "skipped": false,
          "skip_reason": null,
          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 13903,
          "unit_kind": "paragraph"
        },
        "text": "The proposed Act should explicitly address the rapid developments in Artificial Intelligence (AI) and the influence of the attention economy on people's (mental) well-being. Current market incentives encourage companies to capture and retain users' attention for as long as possible. This is to collect more data, sell more ads and products, and expand user bases. With AI's growing influence in the digital world, such practices are expected to become even more pervasive, further undermining individuals' autonomy over the information and experiences presented to them.",
        "chunk_meta": {
          "section_id": "s0",
          "section_path": [],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 84,
          "char_len": 571
        }
      },
      {
        "para_id": "p19",
        "items": [],
        "meta": {
