          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 8146,
          "unit_kind": "paragraph"
        },
        "text": "We therefore recommend that the DFA focus on promoting recognisable disclosures and transparency, while supporting self-regulatory initiatives that have already proven effective, rather than introducing specific disclosures.",
        "chunk_meta": {
          "section_id": "s5",
          "section_path": [
