          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 11623,
          "unit_kind": "paragraph"
        },
        "text": "It is therefore crucial to preserve all GDPR legal bases, including legitimate interest, for data-driven advertising. Limiting these options would reduce the competitiveness of European startups vis-à-vis non-EU players operating under lighter regimes.",
        "chunk_meta": {
          "section_id": "s0",
          "section_path": [],
          "span": null,
