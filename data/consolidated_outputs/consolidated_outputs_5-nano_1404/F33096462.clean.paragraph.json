          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 6034,
          "unit_kind": "paragraph"
        },
        "text": "Policies that create predictable, innovation-friendly conditions will help EU startups compete globally, attract investment, and keep talent within Europe. This is especially crucial as the Union faces strong competition from U.S. and Asian markets, where regulatory frameworks are often more agile and innovation-oriented.",
        "chunk_meta": {
          "section_id": "s2",
          "section_path": [
            "Strengthening Europe's Innovation Ecosystem"
          ],
          "span": null,
          "chunk_quality": "ok",
