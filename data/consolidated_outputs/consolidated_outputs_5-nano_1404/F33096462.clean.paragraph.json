          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 7296,
          "unit_kind": "paragraph"
        },
        "text": "A balanced approach to digital fairness - one that trusts existing rules, promotes consumer protection, and supports entrepreneurial freedom - will strengthen Europe's position as a leader in ethical, sustainable innovation.",
        "chunk_meta": {
          "section_id": "s2",
          "section_path": [
            "Strengthening Europe's Innovation Ecosystem"
          ],
          "span": null,
