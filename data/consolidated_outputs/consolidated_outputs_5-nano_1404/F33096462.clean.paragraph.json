          "errors": [],
          "repaired": false,
          "latency_ms": 5020,
          "unit_kind": "paragraph"
        },
        "text": "Digital Advertising: An Essential Tool for Startups",
        "chunk_meta": {
          "section_id": "s0",
          "section_path": [],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 7,
          "char_len": 51
        }
      },
      {
