        "text": "Bits of Freedom is a Dutch digital rights organization. For over two decades it has been our mission to shape the internet in support of an open and just society. We welcome the Commission’s ambition to ensure fairness for consumers online.",
        "chunk_meta": {
          "section_id": "s1",
          "section_path": [
            "Response to the European Commission’s public consultation for the Digital Fairness Act"
          ],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 42,
          "char_len": 240
        }
      },
      {
        "para_id": "p8",
        "items": [
          {
            "topic": "Design Patterns",
            "topic_source": "dfa",
            "evidence_quotes": [
              {
                "quote": "addictive design"
              }
            ]
          },
          {
            "topic": "Personalisation",
