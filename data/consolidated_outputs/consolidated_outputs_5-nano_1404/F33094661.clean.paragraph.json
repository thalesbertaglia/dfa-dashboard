          "validation_ok": true,
          "errors": [],
          "repaired": false,
          "latency_ms": 11066,
          "unit_kind": "paragraph"
        },
        "text": "Finance Sweden have no position regarding the question whether there is a general need for practices of those influencing through social media to be regulated in some other way differing from general regulations on market practices. However, increasing complexity by introducing new requirements against what is already unallowed should be avoided. It should be noted that the examples given are already unallowed as there are legal requirements to clearly indicate what is advertising, hiding information is misleading the consumer and the use of health claims is regulated by special provisions.",
        "chunk_meta": {
          "section_id": "s4",
          "section_path": [
            "Harmful practices by social media influencers"
          ],
          "span": null,
          "chunk_quality": "ok",
          "chunk_word_count": 90,
