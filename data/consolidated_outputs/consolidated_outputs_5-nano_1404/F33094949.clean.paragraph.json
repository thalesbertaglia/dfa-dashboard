          "repaired": false,
          "latency_ms": 3986,
          "unit_kind": "paragraph"
        },
        "text": "EK welcomes the public consultation on the Digital Fairness Act and is pleased to submit its input for consideration.",
        "chunk_meta": {
          "section_id": "s2",
          "section_path": [
            "Public consultation on the Digital Fairness Act (DFA)",
            "Call for evidence / Feedback"
          ],
          "span": null,
