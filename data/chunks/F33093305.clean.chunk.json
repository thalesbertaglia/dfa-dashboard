      "para_id": "p1",
      "section_id": "s1",
      "section_path": [
        "Introduction"
      ],
      "ordinal": 1,
      "text": "EGBA represents Europe's leading online gambling operators. This Annex brings together the wide range of national rules that our members comply with, in addition to EU rules, regarding dark patterns and addictive design. Please consider the list non-exhaustive and take into consideration dark patterns and addictive designs as described by the European Commission in the Digital Fairness Act (DFA) public consultation.",
      "char_len": 419,
      "chunk_word_count": 61,
      "ratios": {
        "alpha": 0.9749303621169917,
        "digit": 0.0,
        "non_space": 0.8568019093078759
      },
      "meaning": {
        "score": 0.9811977715877438,
        "flags": []
      },
      "selection": {
        "selected": true,
        "policy": "threshold+top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p2",
      "section_id": "s3",
      "section_path": [
        "1. Dark patterns - Regulatory Overview",
        "Belgium"
      ],
      "ordinal": 2,
      "text": "Royal Decree on Advertising: Prohibits glamorising gambling, linking to financial success, loans, alcohol, or vulnerable groups.",
      "char_len": 128,
      "chunk_word_count": 16,
      "ratios": {
        "alpha": 0.9469026548672567,
        "digit": 0.0,
        "non_space": 0.8828125
      },
      "meaning": {
        "score": 0.47128810226155365,
        "flags": []
      },
      "selection": {
        "selected": true,
        "policy": "top_k"
      },
      "chunk_quality": "ok"
    },
    {
