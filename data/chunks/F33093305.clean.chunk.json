      "section_id": "s4",
      "section_path": [
        "1. Dark patterns - Regulatory Overview",
        "Denmark"
      ],
      "ordinal": 3,
      "text": "Marketing Act: Prohibits misleading/unduly aggressive practices, e.g. false urgency.",
