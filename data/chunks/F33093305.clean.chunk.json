    {
      "para_id": "p37",
      "section_id": "s20",
      "section_path": [
        "3. Channelling Data"
      ],
      "ordinal": 37,
      "text": "Recent data from multiple European countries demonstrates the growing scale of Europe’s black market online gambling activity. Therefore, we call on policymakers to prioritise regulation that is evidence-based and behaviourally informed to channel players toward the safer, regulated environment – not away from it. Over-regulation can lead to players choosing the black market, which is one click away.",
      "char_len": 403,
      "chunk_word_count": 58,
      "ratios": {
        "alpha": 0.9710982658959537,
        "digit": 0.0,
        "non_space": 0.858560794044665
      },
      "meaning": {
        "score": 0.9783236994219653,
        "flags": []
      },
      "selection": {
