    {
      "para_id": "p5",
      "section_id": "s1",
      "section_path": [
        "Digital Fairness Act"
      ],
      "ordinal": 5,
      "text": "European DIGITAL SME Alliance - Call for Evidence initial response",
      "char_len": 66,
      "chunk_word_count": 9,
      "ratios": {
        "alpha": 0.9824561403508771,
        "digit": 0.0,
        "non_space": 0.8636363636363636
