    {
      "para_id": "p17",
      "section_id": "s1",
      "section_path": [
        "Digital Fairness Act"
      ],
      "ordinal": 17,
      "text": "the DMA imposes, in Art. 5(2) among other provisions, strong restrictions on gatekeepers' unfair practices",
      "char_len": 106,
      "chunk_word_count": 16,
      "ratios": {
        "alpha": 0.9130434782608695,
        "digit": 0.021739130434782608,
        "non_space": 0.8679245283018868
      },
      "meaning": {
        "score": 0.44589371980676323,
        "flags": []
