        "policy": "top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p46",
      "section_id": "s7",
      "section_path": [
        "Personalization"
      ],
      "ordinal": 46,
      "text": "GDPR prohibits the use of sensitive personal data and restricts profiling of children.",
      "char_len": 86,
      "chunk_word_count": 13,
      "ratios": {
        "alpha": 0.9864864864864865,
        "digit": 0.0,
        "non_space": 0.8604651162790697
      },
