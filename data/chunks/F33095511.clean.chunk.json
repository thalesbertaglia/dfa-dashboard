        "policy": "top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p49",
      "section_id": "s7",
      "section_path": [
        "Personalization"
      ],
      "ordinal": 49,
      "text": "Art 38: follows the right for users to opt out of recommendations based on profiling.",
      "char_len": 85,
      "chunk_word_count": 15,
      "ratios": {
        "alpha": 0.9436619718309859,
        "digit": 0.028169014084507043,
