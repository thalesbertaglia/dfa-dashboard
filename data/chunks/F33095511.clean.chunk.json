      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p51",
      "section_id": "s7",
      "section_path": [
        "Personalization"
      ],
      "ordinal": 51,
      "text": "Art 5(2)(a): bans processing personal data for online advertising services without consent.",
      "char_len": 91,
      "chunk_word_count": 14,
      "ratios": {
        "alpha": 0.9,
        "digit": 0.025,
        "non_space": 0.8791208791208791
      },
      "meaning": {
        "score": 0.40555555555555556,
