      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p47",
      "section_id": "s7",
      "section_path": [
        "Personalization"
      ],
      "ordinal": 47,
      "text": "DSA prohibits profiling of minors based on sensitive data and adds transparency requirements.",
      "char_len": 93,
      "chunk_word_count": 13,
      "ratios": {
        "alpha": 0.9876543209876543,
        "digit": 0.0,
        "non_space": 0.8709677419354839
      },
      "meaning": {
