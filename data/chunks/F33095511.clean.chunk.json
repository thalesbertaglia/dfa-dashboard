      "chunk_quality": "ok"
    },
    {
      "para_id": "p50",
      "section_id": "s7",
      "section_path": [
        "Personalization"
      ],
      "ordinal": 50,
      "text": "DMA art. 15 requires gatekeepers to make their profiling mechanisms transparent.",
      "char_len": 80,
      "chunk_word_count": 11,
      "ratios": {
        "alpha": 0.9428571428571428,
        "digit": 0.02857142857142857,
