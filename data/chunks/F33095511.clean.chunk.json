    },
    {
      "para_id": "p35",
      "section_id": "s4",
      "section_path": [
        "Dark patterns"
      ],
      "ordinal": 35,
      "text": "Art 6 (information obligations (pre-contract)) + art 8 (formal requirements (clarity and visibility))",
      "char_len": 101,
      "chunk_word_count": 12,
      "ratios": {
