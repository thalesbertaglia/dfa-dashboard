    {
      "para_id": "p4",
      "section_id": "s0",
      "section_path": [],
      "ordinal": 4,
      "text": "Date: 23 oktober 2025",
      "char_len": 21,
      "chunk_word_count": 4,
      "ratios": {
        "alpha": 0.6111111111111112,
        "digit": 0.3333333333333333,
        "non_space": 0.8571428571428571
      },
      "meaning": {
