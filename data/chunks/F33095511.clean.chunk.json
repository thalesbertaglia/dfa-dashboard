        "policy": "threshold+top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p60",
      "section_id": "s8",
      "section_path": [
        "Horizontal proposals"
      ],
      "ordinal": 60,
      "text": "These proposals are contrary to the Draghi report, which specifically calls for simplification and reduction of regulatory burden.",
      "char_len": 130,
      "chunk_word_count": 18,
      "ratios": {
        "alpha": 0.9823008849557522,
        "digit": 0.0,
        "non_space": 0.8692307692307693
      },
      "meaning": {
        "score": 0.5283923303834808,
        "flags": []
      },
      "selection": {
        "selected": true,
        "policy": "threshold+top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p61",
      "section_id": "s9",
      "section_path": [
        "Focus on consistent enforcement"
      ],
      "ordinal": 61,
      "text": "The real challenge is fragmented and inconsistent enforcement. The same practice, such as personalization, may be assessed differently by privacy supervisors, consumer authorities, and DSA coordinators. This reduces predictability and hampers innovation.",
      "char_len": 254,
      "chunk_word_count": 32,
      "ratios": {
        "alpha": 0.968609865470852,
        "digit": 0.0,
        "non_space": 0.8779527559055118
      },
      "meaning": {
        "score": 0.7320129546586946,
        "flags": []
      },
      "selection": {
        "selected": true,
        "policy": "threshold+top_k"
      },
      "chunk_quality": "ok"
    },
