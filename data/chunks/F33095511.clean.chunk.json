          "very_short"
        ]
      },
      "selection": {
        "selected": true,
        "policy": "top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p56",
      "section_id": "s8",
      "section_path": [
        "Horizontal proposals"
      ],
      "ordinal": 56,
      "text": "GDPR (e.g. special protection for children, data minimization principle).",
      "char_len": 73,
      "chunk_word_count": 10,
      "ratios": {
        "alpha": 0.9076923076923077,
        "digit": 0.0,
        "non_space": 0.8904109589041096
