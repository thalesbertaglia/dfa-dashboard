    },
    {
      "para_id": "p58",
      "section_id": "s8",
      "section_path": [
        "Horizontal proposals"
      ],
      "ordinal": 58,
      "text": "Accessibility Act (design obligations for at-risk users).",
      "char_len": 57,
      "chunk_word_count": 7,
      "ratios": {
        "alpha": 0.9215686274509803,
        "digit": 0.0,
        "non_space": 0.8947368421052632
      },
      "meaning": {
