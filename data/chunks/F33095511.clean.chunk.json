        "flags": [
          "very_short"
        ]
      },
      "selection": {
        "selected": true,
        "policy": "top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p59",
      "section_id": "s8",
      "section_path": [
        "Horizontal proposals"
      ],
      "ordinal": 59,
      "text": "There is a risk of contradiction with GDPR's data minimization principle if businesses are required to collect more data to identify \"vulnerable\" consumers",
      "char_len": 155,
      "chunk_word_count": 23,
      "ratios": {
        "alpha": 0.9774436090225563,
        "digit": 0.0,
        "non_space": 0.8580645161290322
      },
      "meaning": {
        "score": 0.6011382623224728,
        "flags": []
      },
      "selection": {
