    },
    {
      "para_id": "p57",
      "section_id": "s8",
      "section_path": [
        "Horizontal proposals"
      ],
      "ordinal": 57,
      "text": "DSA (protections for minors and sensitive data).",
      "char_len": 48,
      "chunk_word_count": 7,
      "ratios": {
