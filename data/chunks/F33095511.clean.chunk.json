      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p48",
      "section_id": "s7",
      "section_path": [
        "Personalization"
      ],
      "ordinal": 48,
      "text": "Art. 26: follows transparency obligations for advertising.",
      "char_len": 58,
      "chunk_word_count": 7,
      "ratios": {
        "alpha": 0.9038461538461539,
        "digit": 0.038461538461538464,
        "non_space": 0.896551724137931
