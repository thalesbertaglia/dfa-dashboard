      },
      "chunk_quality": "noisy"
    },
    {
      "para_id": "p44",
      "section_id": "s7",
      "section_path": [
        "Personalization"
      ],
      "ordinal": 44,
      "text": "Personalization offers significant benefits to consumers and businesses: it prevents fraud, increases relevance, limits irrelevant advertising, and supports loyalty. There is already a strong framework governing personalisation.",
      "char_len": 228,
      "chunk_word_count": 27,
      "ratios": {
        "alpha": 0.9702970297029703,
        "digit": 0.0,
        "non_space": 0.8859649122807017
      },
      "meaning": {
        "score": 0.6568894389438944,
        "flags": []
      },
      "selection": {
        "selected": true,
        "policy": "threshold+top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p45",
      "section_id": "s7",
      "section_path": [
        "Personalization"
      ],
      "ordinal": 45,
      "text": "GDPR art. 5(1) and 22 regulate profiling and personalized pricing.",
      "char_len": 66,
      "chunk_word_count": 11,
      "ratios": {
        "alpha": 0.8596491228070176,
        "digit": 0.07017543859649122,
        "non_space": 0.8636363636363636
      },
      "meaning": {
        "score": 0.3447368421052632,
