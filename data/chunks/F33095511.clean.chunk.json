    {
      "para_id": "p34",
      "section_id": "s4",
      "section_path": [
        "Dark patterns"
      ],
      "ordinal": 34,
      "text": "CRD art. 22 prohibits pre-checked boxes and sets clear requirements for buttons and information provision.",
      "char_len": 106,
      "chunk_word_count": 15,
      "ratios": {
