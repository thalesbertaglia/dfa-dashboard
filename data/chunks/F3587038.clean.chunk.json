    },
    {
      "para_id": "p15",
      "section_id": "s6",
      "section_path": [
        "Addendum 2",
        "Annot. 7 “Secondary monetization methods injected into full-priced products”",
        "Examples"
      ],
      "ordinal": 15,
      "text": "The Crew (2014) - video game; the game allows the player to gather regular in-game currency as part of the standard story progression to purchase new vehicles, however the price of some of those vehicles would require unreasonable amount of work spent playing the game, to the point players are incentivized to spend additional real money for a virtual-currency that allows to buy the in-game vehicles cheaper and faster",
      "char_len": 420,
      "chunk_word_count": 68,
      "ratios": {
        "alpha": 0.9630681818181818,
        "digit": 0.011363636363636364,
        "non_space": 0.8380952380952381
      },
      "meaning": {
        "score": 0.9723011363636364,
        "flags": []
      },
      "selection": {
        "selected": true,
        "policy": "threshold+top_k"
      },
