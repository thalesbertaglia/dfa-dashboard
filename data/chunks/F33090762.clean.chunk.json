    },
    {
      "para_id": "p9",
      "section_id": "s2",
      "section_path": [
        "Algorithmic Pluralism"
      ],
      "ordinal": 9,
      "text": "counterhate.com",
      "char_len": 15,
      "chunk_word_count": 2,
      "ratios": {
        "alpha": 0.9333333333333333,
        "digit": 0.0,
        "non_space": 1.0
      },
      "meaning": {
