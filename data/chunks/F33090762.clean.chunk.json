      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p44",
      "section_id": "s3",
      "section_path": [
        "Algorithmic Pluralism",
        "Conclusion"
      ],
      "ordinal": 44,
      "text": "In line with the EU's fundamental principles of freedom, respect for human rights and equality, European consumers have the right to co-construct their digital environments. Consumers with editorial control over their algorithms have complete freedom over how and what content they consume.",
