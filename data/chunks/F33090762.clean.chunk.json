      "section_id": "s3",
      "section_path": [
        "Algorithmic Pluralism",
        "Conclusion"
      ],
      "ordinal": 43,
      "text": "Large online platforms serve an important public function as the online world becomes more relevant to individuals' participation in society. We should require platforms to put people's interests at the heart of the development and deployment of their algorithms.",
      "char_len": 263,
      "chunk_word_count": 39,
      "ratios": {
        "alpha": 0.9822222222222222,
        "digit": 0.0,
        "non_space": 0.8555133079847909
      },
      "meaning": {
        "score": 0.8491666666666666,
        "flags": []
      },
      "selection": {
