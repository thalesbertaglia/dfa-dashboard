      "section_id": "s3",
      "section_path": [
        "1. Avoid mandatory price transparency obligations"
      ],
      "ordinal": 10,
      "text": "existing consumer law (such as the Consumer Rights Directive and Unfair Commercial Practices Directive).",
      "char_len": 104,
      "chunk_word_count": 14,
      "ratios": {
        "alpha": 0.967032967032967,
        "digit": 0.0,
