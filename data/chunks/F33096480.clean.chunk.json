      "section_path": [
        "1. Avoid mandatory price transparency obligations"
      ],
      "ordinal": 9,
      "text": "Middelthuns gate 27 Majorstuen, Oslo, Norway PB 5473 Majorstuen 0305 Oslo, Norway +47 23 08 86 50 nhoservice.no Org. no. 971 491 671",
