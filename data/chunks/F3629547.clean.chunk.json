      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p29",
      "section_id": "s8",
      "section_path": [
        "A. Attracting attention",
        "4. Give users more control over sorting algorithms"
      ],
      "ordinal": 29,
      "text": "Users should be able to choose third-party sorting algorithms. Anyone should be able to design a sorting algorithm that can be used by everyone on a platform.",
      "char_len": 158,
      "chunk_word_count": 27,
      "ratios": {
        "alpha": 0.9772727272727273,
        "digit": 0.0,
        "non_space": 0.8354430379746836
