      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p30",
      "section_id": "s8",
      "section_path": [
        "A. Attracting attention",
        "4. Give users more control over sorting algorithms"
      ],
      "ordinal": 30,
      "text": "Users should be able to customize their chosen sorting algorithm by indicating whether they want to see more or less of certain content and by being able to block certain types of content.",
      "char_len": 188,
      "chunk_word_count": 33,
      "ratios": {
        "alpha": 0.9935897435897436,
        "digit": 0.0,
        "non_space": 0.8297872340425532
