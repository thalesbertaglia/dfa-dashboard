      "para_id": "p0",
      "section_id": "s0",
      "section_path": [],
      "ordinal": 0,
      "text": "Ref. Ares(2025)7366693 - 07/09/2025",
      "char_len": 35,
      "chunk_word_count": 7,
      "ratios": {
        "alpha": 0.21875,
        "digit": 0.59375,
        "non_space": 0.9142857142857143
