    {
      "para_id": "p15",
      "section_id": "s3",
      "section_path": [
        "1. The distinct meaning of \"fairness\""
      ],
      "ordinal": 15,
      "text": "Innovations and technology division 2 / 6",
      "char_len": 41,
      "chunk_word_count": 6,
      "ratios": {
        "alpha": 0.9142857142857143,
        "digit": 0.05714285714285714,
        "non_space": 0.8536585365853658
      },
      "meaning": {
