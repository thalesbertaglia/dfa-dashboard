    },
    {
      "para_id": "p32",
      "section_id": "s5",
      "section_path": [
        "3. Profiling and fairness"
      ],
      "ordinal": 32,
      "text": "DFA complementarity (filling gaps): The DFA explicitly targets unethical practices related to online profiling, particularly when consumer vulnerabilities are exploited for commercial purposes.",
