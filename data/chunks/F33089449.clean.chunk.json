    {
      "para_id": "p36",
      "section_id": "s5",
      "section_path": [
        "3. Profiling and fairness"
      ],
      "ordinal": 36,
      "text": "marketing tactics with broad consumer protection mandates and a special focus on unfair personalization practices such as those based on hyper-personalized algorithmic recommendations and price personalization.",
      "char_len": 210,
      "chunk_word_count": 26,
      "ratios": {
        "alpha": 0.9891891891891892,
        "digit": 0.0,
        "non_space": 0.8809523809523809
      },
      "meaning": {
