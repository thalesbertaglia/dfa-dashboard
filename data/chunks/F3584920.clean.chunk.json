      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p29",
      "section_id": "s3",
      "section_path": [
        "Lost Standards in Gaming: Then vs. Now",
        "1. Full Ownership and Offline Capability"
      ],
      "ordinal": 29,
      "text": "**Then (Pre-2010s):**",
      "char_len": 21,
      "chunk_word_count": 2,
      "ratios": {
        "alpha": 0.4,
        "digit": 0.2,
        "non_space": 0.9523809523809523
      },
      "meaning": {
        "score": 0.0,
        "flags": [
          "very_short",
          "low_alpha",
          "likely_noise"
        ]
      },
      "selection": {
        "selected": false,
        "policy": "threshold"
      },
      "chunk_quality": "noisy"
    },
    {
      "para_id": "p30",
      "section_id": "s3",
      "section_path": [
        "Lost Standards in Gaming: Then vs. Now",
        "1. Full Ownership and Offline Capability"
      ],
      "ordinal": 30,
      "text": "Games were sold complete on physical discs or cartridges.",
      "char_len": 57,
      "chunk_word_count": 9,
      "ratios": {
        "alpha": 0.9795918367346939,
        "digit": 0.0,
        "non_space": 0.8596491228070176
      },
      "meaning": {
        "score": 0.4346938775510204,
        "flags": [
          "very_short"
        ]
      },
