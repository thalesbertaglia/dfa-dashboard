    },
    {
      "para_id": "p28",
      "section_id": "s1",
      "section_path": [
        "Closing Statement:"
      ],
      "ordinal": 28,
      "text": "The erosion of game quality and the rise of manipulative monetization have shifted gaming from a creative artform to a psychological revenue trap. To protect consumers – especially children – it's time to update digital commerce laws to match the realities of modern entertainment.",
      "char_len": 281,
      "chunk_word_count": 42,
      "ratios": {
        "alpha": 0.9789915966386554,
        "digit": 0.0,
        "non_space": 0.8469750889679716
      },
      "meaning": {
        "score": 0.8925770308123249,
        "flags": []
      },
      "selection": {
