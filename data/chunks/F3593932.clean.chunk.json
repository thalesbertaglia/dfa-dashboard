    {
      "para_id": "p16",
      "section_id": "s8",
      "section_path": [
        "Position du groupe La Poste",
        "6. Application et coordination des règles"
      ],
      "ordinal": 16,
      "text": "L'un des principaux défis identifiés est le manque de coordination entre les régulateurs. La coexistence de plusieurs textes (DPCD, DSA, DMA, RGPD) rend l'application complexe.",
      "char_len": 176,
      "chunk_word_count": 28,
      "ratios": {
        "alpha": 0.9407894736842105,
        "digit": 0.0,
        "non_space": 0.8636363636363636
      },
      "meaning": {
        "score": 0.6500365497076024,
        "flags": []
      },
      "selection": {
        "selected": true,
        "policy": "threshold+top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p17",
      "section_id": "s8",
      "section_path": [
        "Position du groupe La Poste",
        "6. Application et coordination des règles"
      ],
      "ordinal": 17,
      "text": "Le groupe La Poste recommande de renforcer la coopération entre les autorités nationales et européennes, notamment via le réseau CPC (Consumer Protection Cooperation Network) et les coordinateurs des services numériques. Une approche plus centralisée, inspirée du droit de la concurrence, pourrait améliorer l'efficacité et la cohérence de l'application des règles.",
      "char_len": 365,
      "chunk_word_count": 60,
      "ratios": {
        "alpha": 0.9715189873417721,
        "digit": 0.0,
        "non_space": 0.8657534246575342
      },
      "meaning": {
        "score": 0.9786392405063291,
        "flags": []
      },
