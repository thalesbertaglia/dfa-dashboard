    {
      "para_id": "p7",
      "section_id": "s3",
      "section_path": [
        "Position du groupe La Poste",
        "1. Préservation du cadre existant"
      ],
      "ordinal": 7,
      "text": "des dispositifs incitatifs ou trompeurs relevant de la logique des dark patterns. Afin d'éviter une éventuelle asymétrie de traitement, toute réflexion réglementaire devrait donc s'inscrire dans une approche cohérente et transversale, prenant en compte l'ensemble des canaux d'interaction avec les consommateurs.",
      "char_len": 312,
      "chunk_word_count": 46,
      "ratios": {
        "alpha": 0.9705882352941176,
        "digit": 0.0,
        "non_space": 0.8717948717948718
      },
      "meaning": {
        "score": 0.9473856209150326,
        "flags": []
      },
      "selection": {
        "selected": true,
