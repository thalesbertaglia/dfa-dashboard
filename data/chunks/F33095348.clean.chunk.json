    {
      "para_id": "p6",
      "section_id": "s1",
      "section_path": [
        "EFAMRO and ESOMAR Consultation Response"
      ],
      "ordinal": 6,
      "text": "EFAMRO the European Federation of Associations of Market Research Organisations. Founded in 1992, EFAMRO represents the interests of market, opinion and social research in Europe. Its members are national trade associations for research businesses.",
      "char_len": 248,
      "chunk_word_count": 34,
      "ratios": {
        "alpha": 0.958139534883721,
        "digit": 0.018604651162790697,
        "non_space": 0.8669354838709677
      },
      "meaning": {
        "score": 0.7547157622739018,
        "flags": []
      },
      "selection": {
        "selected": true,
        "policy": "threshold+top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p7",
      "section_id": "s1",
      "section_path": [
        "EFAMRO and ESOMAR Consultation Response"
      ],
      "ordinal": 7,
      "text": "ESOMAR the worldwide, not-for-profit membership organisation committed to empowering and connecting the research, insights, and analytics community since 1947. Today, ESOMAR represents and provides connections among 50,000+ individuals and 750+ companies in 130+ countries.",
      "char_len": 273,
      "chunk_word_count": 36,
      "ratios": {
        "alpha": 0.8875,
        "digit": 0.0625,
        "non_space": 0.8791208791208791
      },
      "meaning": {
        "score": 0.7322916666666667,
        "flags": []
      },
      "selection": {
        "selected": true,
        "policy": "threshold+top_k"
      },
      "chunk_quality": "ok"
    },
    {
      "para_id": "p8",
      "section_id": "s1",
      "section_path": [
        "EFAMRO and ESOMAR Consultation Response"
      ],
      "ordinal": 8,
      "text": "EFAMRO represent the research and insights sector, accounting for a reported annual turnover of €34.02 billion in Europe.",
      "char_len": 121,
      "chunk_word_count": 19,
      "ratios": {
        "alpha": 0.9230769230769231,
        "digit": 0.038461538461538464,
        "non_space": 0.859504132231405
      },
      "meaning": {
        "score": 0.4992521367521368,
        "flags": []
      },
      "selection": {
        "selected": true,
